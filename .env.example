# Required for local dev (auto-generated on production deploy)
JWT_SECRET=change-me-to-a-random-secret

# OIDC providers — JSON array, one object per sign-in method.
# Each provider needs: name, label, client_id, client_secret, discovery_url.
# Optional: scopes (default: openid email profile), subject_claim (default: sub; use "oid" for Azure).
#
# Google:
#   discovery_url: https://accounts.google.com/.well-known/openid-configuration
#   Create a Web Application client at https://console.cloud.google.com
#   Add <APP_URL>/auth/callback as an Authorized Redirect URI.
#
# Azure Entra ID:
#   discovery_url: https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
#   Register an app at https://entra.microsoft.com; add <APP_URL>/auth/callback as redirect URI.
#   Set subject_claim to "oid" so the stable Azure object ID is used (not the app-specific sub).
#
# Example (single Google provider):
# OIDC_PROVIDERS=[{"name":"google","label":"Google","client_id":"....apps.googleusercontent.com","client_secret":"...","discovery_url":"https://accounts.google.com/.well-known/openid-configuration"}]
#
# Example (Google + Azure, two sign-in buttons):
# OIDC_PROVIDERS=[{"name":"google","label":"Google","client_id":"...","client_secret":"...","discovery_url":"https://accounts.google.com/.well-known/openid-configuration"},{"name":"azure","label":"Epic Azure AD","client_id":"...","client_secret":"...","discovery_url":"https://login.microsoftonline.com/<tenant>/v2.0/.well-known/openid-configuration","subject_claim":"oid"}]
OIDC_PROVIDERS=[]

# Optional: enables per-user encryption at rest
# Production: auto-generated by the deploy script.
# KEY_ENCRYPTION_KEY=generate-a-random-32-byte-key

# Optional: domain for Caddy auto-HTTPS (defaults to localhost)
# DOMAIN=yourdomain.com


# Optional: semicolon-delimited admin emails
# ADMIN_EMAIL=admin@example.com;admin2@example.com

# Optional: push notifications
# VAPID_PUBLIC_KEY=BEl62i...
# VAPID_PRIVATE_KEY=UGr3K...

# Optional: email notifications
# EMAIL_PROVIDER=resend   (default) or smtp
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=Equity Tracker <noreply@yourdomain.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=yourpassword
# SMTP_FROM=Equity Tracker <noreply@yourdomain.com>
# APP_URL=https://yourdomain.com
