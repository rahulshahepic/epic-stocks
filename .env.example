# Required for local dev (auto-generated on production deploy)
JWT_SECRET=change-me-to-a-random-secret

# Auth provider — defaults to 'google'. Set to 'azure_entra' for Microsoft Entra ID.
# AUTH_PROVIDER=google

# Google OAuth (required when AUTH_PROVIDER=google)
# Create an OAuth 2.0 Web Application client at https://console.cloud.google.com
# Add your app's /auth/callback URL as an Authorized Redirect URI.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure Entra ID (required when AUTH_PROVIDER=azure_entra)
# Register an app at https://entra.microsoft.com and add /auth/callback as a redirect URI.
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Optional: enables per-user encryption at rest
# Production: auto-generated by the deploy script.
# ENCRYPTION_MASTER_KEY=generate-a-random-32-byte-key

# Optional: domain for Caddy auto-HTTPS (defaults to localhost)
# DOMAIN=yourdomain.com

# Optional: link to an internal pre-filled onboarding template (e.g. on an internal GitLab instance)
# When set, shows a "On Epic's network? Use this pre-filled template" link on the Import page and Dashboard
# EPIC_ONBOARDING_URL=https://gitlab.internal/your-org/epic-stocks-template

# Optional: semicolon-delimited admin emails
# ADMIN_EMAIL=admin@example.com;admin2@example.com

# Optional: push notifications
# Production: auto-generated by the deploy script.
# Local dev: generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BEl62i...
# VAPID_PRIVATE_KEY=UGr3K...

# Optional: email notifications
# EMAIL_PROVIDER=resend   (default) or smtp
#
# Resend (https://resend.com):
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM=Equity Tracker <noreply@yourdomain.com>
#
# SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=yourpassword
# SMTP_FROM=Equity Tracker <noreply@yourdomain.com>
#
# APP_URL=https://yourdomain.com  # used in email links; defaults to https://$DOMAIN
