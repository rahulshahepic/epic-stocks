# Playwright test runner for local E2E runs via docker-compose.e2e.yml.
# CI runs Playwright directly on the runner (see .github/workflows/test.yml)
# to avoid pulling the ~1.3 GB mcr.microsoft.com/playwright base every build.
FROM mcr.microsoft.com/playwright:v1.56.0-jammy

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

COPY frontend/ ./
COPY test_data/ /test_data/

CMD ["npx", "playwright", "test"]
